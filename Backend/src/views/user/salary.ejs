<!DOCTYPE html>
<html>

<head>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&display=swap"
    rel="stylesheet">
</head>

<body style="font-family: 'Roboto', sans-serif;">
  <div style="height: 1164px; width: 779px ; background: white; padding: 80px;">
    <div style="background:White; width: 100%; height: 100%; position: relative;">
      <div class="main-body" style="    height: 1090px;">
        <div class="header" style="width: 100%;">
          <div>
            <img
              src="data:image/png;base64,"
              style="height: 80%;">
          </div>
          <div style="background-color: #c26b25;text-align: center; color: #ffffff;font-size: 18px">
            <span>www.krishnais.com</span>
          </div>
          <div style="padding: 20px; font-size: 22px; text-align: center;font-weight: 600;">
            <span>Salary Slip</span>
          </div>
          <div class="employdetail">
            <ul style="list-style: none; padding: 0; font-weight:400;line-height: 1.6; font-size: 15px;">
              <li>
                <span>Employee Name: </span> <span><%- salaryDetails.userId.name %></span>
              </li>
              <li>
                <span>Employee Code: </span> <span><%- salaryDetails.userId.emp_id %></span>
              </li>
              <li>
                <span>Designation: </span> <span><%- salaryDetails.userId.designation %></span>
              </li>
              <li>
                <span>Month & Year: </span> <span> <%- salaryDetails.month %>, <%- salaryDetails.year %></span>
              </li>
            </ul>
          </div>
        </div>
        <div class="Earnings">
          <p style="margin-top: 30px;"><b>Earnings:</b></p>
          <table style="width: 90%; border-collapse: collapse; margin: auto;">
            <tbody>
              <% if (salaryDetails && salaryDetails.basic) { %>
                <tr>
                  <td style="border-bottom: 1px solid #ccc; padding: 7px; width: 83%;">Basic</td>
                  <td style="border-bottom: 1px solid #ccc; padding: 7px; text-align: left;">Rs <%- 
                    salaryDetails.basic.toLocaleString('en-IN') %></td>
                </tr>
                <% } %>
                  <% if (salaryDetails && salaryDetails.hra) { %>
                    <tr>
                      <td style="border-bottom: 1px solid #ccc; padding: 7px; width: 83%;">HRA</td>
                      <td style="border-bottom: 1px solid #ccc; padding: 7px; text-align: left;">Rs <%-
                        salaryDetails.hra.toLocaleString('en-IN') %></td>
                    </tr>
                    <% } %>
                      <% if (salaryDetails && salaryDetails.cca) { %>
                        <tr>
                          <td style="border-bottom: 1px solid #ccc; padding: 7px; width: 83%;">CCA</td>
                          <td style="border-bottom: 1px solid #ccc; padding: 7px; text-align: left;">Rs <%-
                            salaryDetails.cca.toLocaleString('en-IN') %></td>
                        </tr>
                        <% } %>
                          <% if (salaryDetails && salaryDetails.medical) { %>
                            <tr>
                              <td style="border-bottom: 1px solid #ccc; padding: 7px; width: 83%;">Medical</td>
                              <td style="border-bottom: 1px solid #ccc; padding: 7px; text-align: left;">Rs <%-
                                salaryDetails.medical.toLocaleString('en-IN') %></td>
                            </tr>
                            <% } %>
                              <% if (salaryDetails && salaryDetails.transport) { %>
                                <tr>
                                  <td style="border-bottom: 1px solid #ccc; padding: 7px; width: 83%;">Transport</td>
                                  <td style="border-bottom: 1px solid #ccc; padding: 7px; text-align: left;">Rs <%-
                                    salaryDetails.transport.toLocaleString('en-IN') %></td>
                                </tr>
                                <% } %>
                                  <% if (salaryDetails && salaryDetails.employer_pf) { %>
                                    <tr>
                                      <td style="border-bottom: 1px solid #ccc; padding: 7px; width: 83%;">Employer PF</td>
                                      <td style="border-bottom: 1px solid #ccc; padding: 7px; text-align: left;">Rs
                                        <%- salaryDetails.employer_pf.toLocaleString('en-IN') %>
                                      </td>
                                    </tr>
                                    <% } %>
                                      <% if (salaryDetails && salaryDetails.performance_incentive) { %>
                                        <tr>
                                          <td style="border-bottom: 1px solid #ccc; padding: 7px; width: 83%;">Performance Incentive
                                          </td>
                                          <td style="border-bottom: 1px solid #ccc; padding: 7px; text-align: left;">Rs
                                            <%- salaryDetails.performance_incentive.toLocaleString('en-IN') %>
                                          </td>
                                        </tr>
                                        <% } %>
            </tbody>
          </table>
        </div>
        <div class="deduction">
          <p style="margin-top: 40px;"><b>Deductions:</b></p>
          <table style="width: 90%; border-collapse: collapse; margin: auto;">
            <tbody>
              <% if (salaryDetails && salaryDetails.pf_deduction) { %>
                <tr>
                  <td style="border-bottom: 1px solid #ccc; padding: 7px; width: 83%;">PF Deduction </td>
                  <td style="border-bottom: 1px solid #ccc; padding: 7px; text-align: left;">Rs <%-
                    salaryDetails.pf_deduction.toLocaleString('en-IN') %></td>
                </tr>
                <% } %>
                  <% if (salaryDetails && salaryDetails.esi_deduction) { %>
                    <tr>
                      <td style="border-bottom: 1px solid #ccc; padding: 7px; width: 83%;">ESI Deduction</td>
                      <td style="border-bottom: 1px solid #ccc; padding: 7px; text-align: left;">Rs <%-
                        salaryDetails.esi_deduction.toLocaleString('en-IN') %></td>
                    </tr>
                    <% } %>
                      <% if (salaryDetails && salaryDetails.professional_tax) { %>
                        <tr>
                          <td style="border-bottom: 1px solid #ccc; padding: 7px; width: 83%;">Professional Tax</td>
                          <td style="border-bottom: 1px solid #ccc; padding: 7px; text-align: left;">Rs <%-
                            salaryDetails.professional_tax.toLocaleString('en-IN') %></td>
                        </tr>
                        <% } %>
                        <% if (salaryDetails && salaryDetails.medical_insurance) { %>
                            <tr>
                              <td style="border-bottom: 1px solid #ccc; padding: 7px; width: 83%;">Medical Insurance</td>
                              <td style="border-bottom: 1px solid #ccc; padding: 7px; text-align: left;">Rs <%-
                                salaryDetails.medical_insurance.toLocaleString('en-IN') %></td>
                            </tr>
                        <% } %>
                        <% if (salaryDetails && salaryDetails.income_tax) { %>
                                <tr>
                                  <td style="border-bottom: 1px solid #ccc; padding: 7px; width: 83%;">Income Tax</td>
                                  <td style="border-bottom: 1px solid #ccc; padding: 7px; text-align: left;">Rs <%-
                                    salaryDetails.income_tax.toLocaleString('en-IN') %></td>
                                </tr>
                        <% } %>
                        <% if (salaryDetails && salaryDetails.leave_deduction) { %>
                                <tr>
                                  <td style="border-bottom: 1px solid #ccc; padding: 7px; width: 83%;">Leave Deduction</td>
                                  <td style="border-bottom: 1px solid #ccc; padding: 7px; text-align: left;">Rs <%-
                                    salaryDetails.leave_deduction.toLocaleString('en-IN') %></td>
                                </tr>
                        <% } %>  
            </tbody>
          </table>
        </div>
        <div class="totals" style="display:block">
          <div style="width: calc(100% - 45px);">
            <p style="display: flex; justify-content: space-between;width: calc(100% - 0px); flex-wrap: wrap;"><b style="width:85%">Net Salary:</b><span style="width:calc(100% - 85%); text-align: left;"><b>Rs <%- net_salary.toLocaleString('en-IN') %></b></span></p>
            <ul style="list-style: none;    padding: 0;    font-weight:400;line-height: 2; font-size: 15px;">
              <li>
                <span>Rupees: </span> <span><%- netSalaryInWords %> only</span>
              </li>
              <li>
                <% const currentDate=new Date(); %>
                  <span>Date: </span> <span>
                    <%= currentDate.getDate() %>/<%= currentDate.getMonth() + 1 %>/<%= currentDate.getFullYear() %>
                  </span>
              </li>
            </ul>
          </div>
        </div>
        <div style="margin-right: 0; margin-left: auto; text-align: right; width: 100%;">
